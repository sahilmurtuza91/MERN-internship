<!DOCTYPE html>
<html lang="en">

<head>
    <%- include("./partials/head") %>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Discover Stories</title>

        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link
            href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Space+Mono:wght@400;700&display=swap"
            rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

        <style>
            :root {
                --bg-main: #0b0f19;
                /* Standard soft deep dark background */
                --glass-card: rgba(22, 28, 45, 0.6);
                /* Slightly lighter background for all cards */
                --neon-glow: #818cf8;
                /* Lighter indigo for better dark mode visibility */
                --text-pure: #ffffff;
                --text-readable: #e2e8f0;
                /* Ultra readable light grey for paragraphs */
                --text-muted-bright: #94a3b8;
                /* Enhanced small text color for metadata */
            }

            body {
                background-color: var(--bg-main);
                color: var(--text-pure);
                font-family: 'Plus Jakarta Sans', sans-serif;
                -webkit-font-smoothing: antialiased;
                overflow-x: hidden;
            }

            a {
                text-decoration: none;
            }

            .tech-mono {
                font-family: 'Space Mono', monospace;
                font-size: 0.78rem;
                letter-spacing: 1px;
            }


            /* High Contrast Bento Plate - Back to Sleek Dark Mode */
            .bento-plate {
                background: var(--glass-card);
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                border: 1px solid rgba(255, 255, 255, 0.08) !important;
                border-radius: 24px !important;
                transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s ease, box-shadow 0.4s ease;
                position: relative;
                overflow: hidden;
            }

            /* 0% Lag CSS Hover Animation */
            .bento-plate:hover {
                transform: translateY(-5px);
                border-color: rgba(129, 140, 248, 0.4) !important;
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 30px rgba(129, 140, 248, 0.05) !important;
            }

            .media-aspect {
                position: relative;
                width: 100%;
                height: 240px;
                overflow: hidden;
                border-radius: 16px;
            }

            .feature-card .media-aspect {
                height: 340px;
            }

            @media (max-width: 768px) {
                .feature-card .media-aspect {
                    height: 220px;
                }
            }

            .bento-img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
            }

            .bento-plate:hover .bento-img {
                transform: scale(1.03);
            }

            /* 🔥 Aapka Idea: White Background Badges for Ultimate Pop! */
            .status-badge-highlight {
                position: absolute;
                top: 16px;
                left: 16px;
                background: #ffffff !important;
                /* Pure White Background */
                color: #0b0f19 !important;
                /* Dark text inside for high contrast */
                border: none !important;
                font-weight: 700;
                padding: 5px 14px;
                border-radius: 8px;
                z-index: 2;
                box-shadow: 0 4px 15px rgba(255, 255, 255, 0.25);
                /* Subtle white glow */
            }

            .article-headline {
                color: var(--text-pure);
                text-decoration: none;
                font-weight: 800;
                line-height: 1.3;
                transition: color 0.2s ease;
            }

            .bento-plate:hover .article-headline {
                color: #a5b4fc;
            }

            /* High Contrast Texts for Easy Reading */
            .readable-desc {
                color: var(--text-readable) !important;
                line-height: 1.7;
                font-size: 0.95rem;
                opacity: 0.9;
            }

            .header-desc {
                color: #cbd5e1 !important;
                font-size: 1rem;
            }

            .meta-text-fixed {
                color: var(--text-muted-bright) !important;
                font-weight: 600;
            }

            /* Terminal Style Action Buttons */
            .terminal-btn {
                background: transparent;
                color: var(--text-pure);
                border: 1px solid rgba(255, 255, 255, 0.2);
                padding: 8px 18px;
                border-radius: 12px;
                font-weight: 600;
                font-size: 0.85rem;
                transition: all 0.2s ease;
                display: inline-flex;
                align-items: center;
                gap: 8px;
            }

            .bento-plate:hover .terminal-btn {
                background: #ffffff;
                color: #000000;
                border-color: #ffffff;
            }

            .author-sig {
                width: 32px;
                height: 32px;
                background: rgba(255, 255, 255, 0.1);
                border: 1px solid rgba(255, 255, 255, 0.2);
                color: var(--text-pure);
                font-weight: 700;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 50%;
                font-size: 0.8rem;
            }
        </style>
</head>

<body>
    <%- include("./partials/nav") %>

        <main class="container my-5 pt-3">

            <!-- Premium Section Header -->
            <header class="row mb-5">
                <div class="col-12 text-center text-md-start">
                    <div class="d-inline-flex align-items-center gap-2 tech-mono mb-2" style="color: var(--neon-glow);">
                        <span class="d-inline-block rounded-circle"
                            style="width: 6px; height: 6px; background-color: var(--neon-glow); box-shadow: 0 0 8px var(--neon-glow);"></span>
                        SYSTEM CORE ACTIVE
                    </div>
                    <h1 class="fw-extrabold display-4 mb-2 text-white" style="letter-spacing: -2px; font-weight: 800;">
                        Engineering Log</h1>
                    <p class="header-desc col-lg-6 px-0">An elite space designed to trace down complex computer science
                        architectures, notes, and development scripts.</p>
                </div>
            </header>

            <!-- Bento Grid System Feed -->
            <div class="row g-4 pb-5">

                <% if (blogs.length===0) { %>
                    <div class="col-12 py-5 text-center">
                        <div class="bento-plate p-5 mx-auto" style="max-width: 500px;">
                            <i class="bi bi-terminal display-4 text-muted mb-3 d-block"></i>
                            <h5 class="fw-bold tech-mono text-uppercase tracking-wider mb-2">[ Thread Empty ]</h5>
                            <p class="text-muted small">No logs compiled on the server yet.</p>
                        </div>
                    </div>
                    <% } %>

                        <% blogs.forEach((blog, index)=> { %>

                            <% if (index===0) { %>
                                <!-- Featured Card (Main Bento Plate) -->
                                <div class="col-12 mb-2 feature-card">
                                    <article class="bento-plate p-4 p-md-5">
                                        <div class="row g-4 align-items-center">
                                            <div class="col-lg-6">
                                                <div class="media-aspect">
                                                    <img src="<%= blog.coverImageURL %>" class="bento-img"
                                                        alt="<%= blog.title %>" loading="lazy">
                                                    <!-- White Badge On Main Image -->
                                                    <span class="status-badge-highlight tech-mono">FEATURED
                                                        SYSTEM</span>
                                                </div>
                                            </div>
                                            <div class="col-lg-6 px-md-4 d-flex flex-column justify-content-center">
                                                <div
                                                    class="d-flex align-items-center gap-3 tech-mono mb-3 meta-text-fixed">
                                                    <span><i class="bi bi-cpu"></i> KERNEL LOG</span>
                                                    <span>•</span>
                                                    <span>
                                                        <%= Math.max(1, Math.ceil(blog.content.length / 450)) %> MIN
                                                            READ
                                                    </span>
                                                </div>
                                                <h2 class="display-6 mb-3">
                                                    <a href="/blog/<%= blog._id %>" class="article-headline">
                                                        <%= blog.title %>
                                                    </a>
                                                </h2>
                                                <p class="readable-desc mb-4">
                                                    <%= blog.content.substring(0, 180) %>
                                                        <%= blog.content.length> 180 ? '...' : '' %>
                                                </p>
                                                <div class="d-flex align-items-center justify-content-between mt-2">
                                                    <div class="d-flex align-items-center gap-2">
                                                        <div class="author-sig">
                                                            <%= blog.author.fullName.charAt(0).toUpperCase() %>
                                                        </div>
                                                        <span class="meta-text-fixed small">
                                                            <%= blog.author.fullName %>
                                                        </span>
                                                    </div>
                                                    <!-- <a href="/blog/<%= blog._id %>" class="terminal-btn">
                                            Execute <i class="bi bi-terminal-fill"></i>
                                        </a> -->
                                                    <a href="/blog/<%= blog._id %>" class="terminal-btn">
                                                        Execute <i class="bi bi-chevron-right"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </article>
                                </div>
                                <% } else { %>
                                    <!-- Secondary Bento Cards (Sub Stations) -->
                                    <div class="col-12 col-md-6 col-lg-4 d-flex">
                                        <article class="bento-plate p-4 w-100 d-flex flex-column">
                                            <div class="media-aspect mb-4">
                                                <img src="<%= blog.coverImageURL %>" class="bento-img"
                                                    alt="<%= blog.title %>" loading="lazy">
                                                <!-- White Badge On Secondary Sub-Station Images -->
                                                <span class="status-badge-highlight tech-mono">SUB_STATION</span>
                                            </div>

                                            <div class="d-flex flex-column flex-grow-1">
                                                <div
                                                    class="d-flex align-items-center gap-3 tech-mono mb-3 meta-text-fixed">
                                                    <span><i class="bi bi-terminal"></i> CORE_LOG</span>
                                                    <span>
                                                        <%= Math.max(1, Math.ceil(blog.content.length / 450)) %> MIN
                                                    </span>
                                                </div>

                                                <h3 class="h5 mb-3">
                                                    <a href="/blog/<%= blog._id %>" class="article-headline">
                                                        <%= blog.title %>
                                                    </a>
                                                </h3>

                                                <p class="readable-desc mb-4 flex-grow-1">
                                                    <%= blog.content.substring(0, 110) %>
                                                        <%= blog.content.length> 110 ? '...' : '' %>
                                                </p>

                                                <div
                                                    class="d-flex align-items-center justify-content-between pt-3 border-top border-secondary border-opacity-10 mt-auto">
                                                    <div class="d-flex align-items-center gap-2">
                                                        <div class="author-sig">
                                                            <%= blog.author.fullName.charAt(0).toUpperCase() %>
                                                        </div>
                                                        <span class="meta-text-fixed small">
                                                            <%= blog.author.fullName %>
                                                        </span>
                                                    </div>
                                                    <a href="/blog/<%= blog._id %>" class="terminal-btn">
                                                        View <i class="bi bi-chevron-right"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        </article>
                                    </div>
                                    <% } %>

                                        <% }) %>

            </div>
        </main>

        <%- include("./partials/script") %>
</body>

</html>