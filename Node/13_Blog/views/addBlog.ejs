<!DOCTYPE html>
<html lang="en">

<head>
    <%- include("./partials/head") %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create New Blog — Blogify</title>
    
    <!-- Google Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        :root {
            --bg-color: #0b0f19;      /* Deep background */
            --card-bg: #111827;       /* Gray 900 for solid chassis */
            --input-bg: #1f2937;      /* Gray 800 - Clear distinct input boxes */
            --border-color: #4b5563;  /* High contrast gray-600 border for sharp clarity */
            --accent-glow: #818cf8;   /* Light indigo */
            --text-pure: #ffffff;
            --text-muted-bright: #cbd5e1; /* Clear bright light-gray for subtext */
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-pure);
            font-family: 'Plus Jakarta Sans', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        .tech-mono {
            font-family: 'Space Mono', monospace;
            font-size: 0.8rem;
            letter-spacing: 0.5px;
        }

        /* High Visibility Cards */
        .workspace-card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color) !important;
            border-radius: 16px !important;
            padding: 32px !important;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
        }

        /* BRIGHT HIGH-CONTRAST LABELS */
        .custom-label-fixed {
            font-weight: 700;
            font-size: 0.85rem;
            color: #f8fafc !important; /* Pure light off-white labels */
            margin-bottom: 10px;
            display: block;
        }

        /* DYNAMIC HIGH-VISIBILITY INPUTS */
        .clean-input-fixed {
            background-color: var(--input-bg) !important;
            border: 1px solid var(--border-color) !important;
            border-radius: 10px !important;
            color: #ffffff !important;
            padding: 12px 16px;
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }

        /* Fixed Invisible Placeholders */
        .clean-input-fixed::placeholder {
            color: #94a3b8 !important; /* Extremely readable placeholder gray */
            opacity: 1;
        }

        .clean-input-fixed:focus {
            outline: none !important;
            border-color: var(--accent-glow) !important;
            box-shadow: 0 0 0 3px rgba(129, 140, 248, 0.25) !important;
        }

        /* Real-Time Preview Panel (Right Side Styling) */
        .dummy-card-fixed {
            background-color: #1e293b; /* Brighter slate for preview block */
            border: 1px solid var(--border-color);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0,0,0,0.4);
        }

        .dummy-img-wrap {
            width: 100%;
            height: 170px;
            background: #334155;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #94a3b8;
            position: relative;
        }

        .status-badge-white {
            position: absolute;
            top: 12px;
            left: 12px;
            background: #ffffff;
            color: #0b0f19;
            font-weight: 800;
            font-size: 0.72rem;
            padding: 5px 12px;
            border-radius: 6px;
            text-transform: uppercase;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

        /* Solid White Publish Action Trigger */
        .btn-publish-action {
            background-color: #ffffff !important;
            color: #0b0f19 !important;
            border: none;
            padding: 14px;
            border-radius: 10px;
            font-weight: 700;
            font-size: 1rem;
            transition: all 0.2s ease;
            width: 100%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-publish-action:hover {
            background-color: #f1f5f9 !important;
            transform: translateY(-1px);
            box-shadow: 0 10px 25px rgba(255, 255, 255, 0.2);
        }

        .text-muted-fixed {
            color: #cbd5e1 !important; /* Fixed invisible descriptions */
        }
    </style>
</head>

<body>
    <!-- Premium Dynamic Connected Navbar -->
    <%- include("./partials/nav") %>

    <div class="container my-5 py-2">
        
        <!-- Header Text Block -->
        <header class="row mb-4 ms-1">
            <div class="col-12 text-start">
                <h1 class="fw-extrabold display-5 text-white" style="letter-spacing: -1.5px; font-weight: 800;">Create New Blog</h1>
                <p class="text-muted-fixed small mb-0">Fill out the parameters below to draft a detailed blog post entry.</p>
            </div>
        </header>

        <!-- Form Split Layout -->
        <div class="row g-4 justify-content-center">
            
            <!-- LEFT AREA: Input Field Engine -->
            <div class="col-12 col-lg-7">
                <div class="card workspace-card">
                    <form action="/blog" method="POST" enctype="multipart/form-data">
                        
                        <!-- Title Field -->
                        <div class="mb-4">
                            <label class="form-label custom-label-fixed">Blog Title</label>
                            <input type="text" id="inputTitle" class="form-control clean-input-fixed" name="title" placeholder="Enter a sharp blog title..." encoding="utf-8" required />
                        </div>

                        <div class="row">
                            <!-- Category Field -->
                            <div class="col-md-6 mb-4">
                                <label class="form-label custom-label-fixed">Category / Classification</label>
                                <select id="inputCategory" class="form-select clean-input-fixed" name="category" required>
                                    <option value="" disabled selected style="color: #94a3b8;">Select Category</option>
                                    <option value="Frontend">Frontend Dev</option>
                                    <option value="Backend">Backend Systems</option>
                                    <option value="DevOps">DevOps & Cloud</option>
                                    <option value="Database">Database Management</option>
                                    <option value="Security">Cybersecurity</option>
                                    <option value="AI">Artificial Intelligence</option>
                                    <option value="JavaScript">JavaScript</option>
                                    <option value="Others">Others</option>
                                </select>
                            </div>

                            <!-- Cover Image Field -->
                            <div class="col-md-6 mb-4">
                                <label class="form-label custom-label-fixed">Cover Asset Image</label>
                                <input type="file" id="inputImage" class="form-control clean-input-fixed" name="coverImage" accept="image/*" required />
                            </div>
                        </div>

                        <!-- Summary Field -->
                        <div class="mb-4">
                            <label class="form-label custom-label-fixed">Short Summary (Sub-heading)</label>
                            <input type="text" id="inputSummary" class="form-control clean-input-fixed" name="summary" placeholder="Write a brief subtitle snippet entry..." required />
                        </div>

                        <!-- Content Field -->
                        <div class="mb-4">
                            <label class="form-label custom-label-fixed">Blog Content Buffer</label>
                            <textarea class="form-control clean-input-fixed" name="content" rows="8" placeholder="Type core analysis or content script data here..." required></textarea>
                        </div>

                        <div class="pt-2">
                            <button type="submit" class="btn-publish-action">
                                Publish Detailed Blog <i class="bi bi-send-fill ms-1"></i>
                            </button>
                        </div>

                    </form>
                </div>
            </div>

            <!-- RIGHT AREA: High Contrast Live Display Preview Grid -->
            <div class="col-12 col-lg-5 d-none d-lg-block ps-xl-4">
                <div class="position-sticky" style="top: 100px;">
                    <div class="d-flex align-items-center gap-2 tech-mono mb-3" style="color: #94a3b8; font-weight: 700;">
                        <i class="bi bi-eye-fill"></i> REAL-TIME DISPLAY LOG STREAM
                    </div>
                    
                    <!-- High Visibility Display Blueprint Chassis -->
                    <div class="dummy-card-fixed">
                        <div class="dummy-img-wrap" id="previewImgContainer">
                            <i class="bi bi-image display-6 text-white-50" id="previewPlaceholderIcon"></i>
                            <img src="" id="realtimeImage" style="display:none; width:100%; height:100%; object-fit:cover;">
                            <span class="status-badge-white tech-mono" id="realtimeCategory">Category</span>
                        </div>
                        <div class="p-4">
                            <div class="tech-mono mb-2" style="font-size: 0.72rem; color: #cbd5e1; font-weight: 600;">
                                <i class="bi bi-terminal-dash me-1"></i> LOG_STREAM // 1 MIN READ
                            </div>
                            <h4 class="fw-bold text-white mb-2" id="realtimeTitle" style="line-height: 1.35;">Untitled Article Document</h4>
                            <p class="small mb-0" id="realtimeSummary" style="font-size: 0.88rem; line-height: 1.5; color: #cbd5e1 !important;">
                                Your short subtitle entry descriptor snippet will render dynamically right over here...
                            </p>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- Live Sync Logic Script -->
    <script>
        const inputTitle = document.getElementById('inputTitle');
        const inputSummary = document.getElementById('inputSummary');
        const inputCategory = document.getElementById('inputCategory');
        const inputImage = document.getElementById('inputImage');

        const rtTitle = document.getElementById('realtimeTitle');
        const rtSummary = document.getElementById('realtimeSummary');
        const rtCategory = document.getElementById('realtimeCategory');
        const rtImage = document.getElementById('realtimeImage');
        const placeholderIcon = document.getElementById('previewPlaceholderIcon');

        inputTitle.addEventListener('input', (e) => {
            rtTitle.textContent = e.target.value.trim() !== "" ? e.target.value : "Untitled Article Document";
        });

        inputSummary.addEventListener('input', (e) => {
            rtSummary.textContent = e.target.value.trim() !== "" ? e.target.value : "Your short subtitle entry descriptor snippet will render dynamically right over here...";
        });

        inputCategory.addEventListener('change', (e) => {
            rtCategory.textContent = e.target.value;
        });

        inputImage.addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.addEventListener('load', function() {
                    rtImage.setAttribute('src', this.result);
                    rtImage.style.display = 'block';
                    placeholderIcon.style.display = 'none';
                });
                reader.readAsDataURL(file);
            }
        });
    </script>

    <%- include("./partials/script") %>
</body>
</html>