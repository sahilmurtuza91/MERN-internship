<!DOCTYPE html>
<html lang="en">

<head>
    <%- include("./partials/head") %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account — Blogify</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        :root {
            --bg-color: #0b0f19;      /* Core dark background */
            --card-bg: #111827;       /* Soft dark gray card bg */
            --input-bg: #1f2937;      /* Clear lighter gray for inputs */
            --border-color: #374151;  /* High contrast light border */
            --accent-color: #818cf8;  /* Indigo accent color */
        }

        body {
            background-color: var(--bg-color);
            color: #ffffff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        /* Clean Minimal Auth Card */
        .clean-auth-card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color) !important;
            border-radius: 16px !important;
            padding: 32px !important;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        }

        .form-heading {
            font-weight: 800;
            letter-spacing: -1px;
            color: #ffffff;
        }

        .form-subheading {
            color: #94a3b8 !important;
            font-size: 0.9rem;
            font-weight: 500;
        }

        .custom-label {
            font-weight: 600;
            font-size: 0.88rem;
            color: #f1f5f9;
            margin-bottom: 8px;
        }

        /* High-Contrast Inputs */
        .clean-input {
            background-color: var(--input-bg) !important;
            border: 1px solid var(--border-color) !important;
            border-radius: 10px !important;
            color: #ffffff !important;
            padding: 12px 16px;
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }

        .clean-input::placeholder {
            color: #6b7280;
        }

        .clean-input:focus {
            outline: none !important;
            border-color: var(--accent-color) !important;
            box-shadow: 0 0 0 3px rgba(129, 140, 248, 0.2) !important;
        }

        /* Solid White Action Button */
        .btn-signup {
            background-color: #ffffff !important;
            color: #0b0f19 !important;
            border: none;
            padding: 12px;
            border-radius: 10px;
            font-weight: 700;
            font-size: 0.95rem;
            transition: all 0.2s ease;
            width: 100%;
        }

        .btn-signup:hover {
            background-color: #f1f5f9 !important;
            transform: translateY(-1px);
            box-shadow: 0 10px 20px rgba(255, 255, 255, 0.1);
        }
    </style>
</head>

<body>
    <%- include("./partials/nav") %>

    <div class="container d-flex align-items-center justify-content-center" style="min-height: 85vh;">
        <div class="w-100" style="max-width: 450px;">
            
            <div class="text-center mb-4">
                <h2 class="form-heading mb-1">Get Started</h2>
                <p class="form-subheading">Create an account to deploy your own technical logs.</p>
            </div>

            <div class="card clean-auth-card">
                <form action="/users/signup" method="post">
                    
                    <div class="mb-4">
                        <label class="form-label custom-label" for="fullName">Full Name</label>
                        <input type="text" class="form-control clean-input" name="fullName" id="fullName" placeholder="Enter your full name" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label custom-label" for="email">Email Address</label>
                        <input type="email" class="form-control clean-input" name="email" id="email" placeholder="name@example.com" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label custom-label" for="password">Password</label>
                        <input type="password" class="form-control clean-input" name="password" id="password" placeholder="Create a strong password" required>
                    </div>

                    <div class="pt-2">
                        <button type="submit" class="btn-signup">
                            <i class="bi bi-person-plus-fill me-2"></i>Sign Up
                        </button>
                    </div>
                    
                </form>
            </div>

        </div>
    </div>

    <%- include("./partials/script") %>
</body>

</html>