<nav class="navbar navbar-expand-lg sticky-top premium-nav">
    <div class="container">
        <!-- Logo -->
        <a class="navbar-brand fw-black tracking-tight" href="/">
            <i class="bi bi-terminal-inner me-2 text-indigo"></i>Blogify
        </a>
        
        <!-- Mobile Trigger -->
        <button class="navbar-toggler custom-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
            <span class="bi bi-list"></span>
        </button>

        <!-- Links Grid -->
        <div class="collapse navbar-collapse" id="navbarNavDropdown">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4 gap-2">
                <!-- HOME -->
                <li class="nav-item">
                    <a class="nav-link <%= typeof currentPath !== 'undefined' && currentPath === '/' ? 'active-link' : '' %>" href="/">
                        <i class="bi bi-house-door me-1"></i> Home
                    </a>
                </li>

                <!-- DYNAMIC CONDITIONAL LINKS BASED ON LOGGED IN USER -->
                <% if (locals.user) { %>
                    <li class="nav-item">
                        <a class="nav-link <%= typeof currentPath !== 'undefined' && currentPath === '/blog/add-new' ? 'active-link' : '' %>" href="/blog/add-new">
                            <i class="bi bi-plus-circle me-1"></i> Add Blog
                        </a>
                    </li>
                <% } else { %>
                    <li class="nav-item">
                        <a class="nav-link <%= typeof currentPath !== 'undefined' && currentPath === '/users/signup' ? 'active-link' : '' %>" href="/users/signup">
                            <i class="bi bi-person-plus me-1"></i> Create Account
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= typeof currentPath !== 'undefined' && currentPath === '/users/signin' ? 'active-link' : '' %>" href="/users/signin">
                            <i class="bi bi-box-arrow-in-right me-1"></i> SignIn
                        </a>
                    </li>
                <% } %>
            </ul>
            
            <!-- Right-Side Profile Dropdown (Only appears if user is logged in) -->
            <% if (locals.user) { %>
                <div class="navbar-nav ms-auto align-items-center">
                    <div class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle profile-trigger d-flex align-items-center gap-2" href="#" id="userDrop" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="nav-avatar-circle">
                                <%= user.fullName.charAt(0).toUpperCase() %>
                            </div>
                            <span class="text-white-50 fw-semibold"><%= user.fullName %></span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end premium-dropdown" aria-labelledby="userDrop">
                            <li>
                                <a class="dropdown-item text-danger d-flex align-items-center gap-2" href="/users/logout">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</nav>

<!-- HIGH CONTRAST DARK MODE ERROR MESSAGE BOX -->
<% if (locals.error) { %>
  <div class="container mt-4" style="max-width: 500px;">
      <div class="alert custom-danger-alert d-flex align-items-center gap-2" role="alert">
          <i class="bi bi-exclamation-triangle-fill fs-5"></i>
          <div>
              Invalid Email or password!
          </div>
      </div>
  </div>
<% } %>

