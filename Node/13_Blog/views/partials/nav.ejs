        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        padding: 14px 0;
        z-index: 1030;
    }

    .navbar-brand {
        color: #ffffff !important;
        font-weight: 800;
        font-size: 1.35rem;
        letter-spacing: -0.5px;
    }

    .text-indigo {
        color: #818cf8;
    }

    .premium-nav .nav-link {
        color: #94a3b8 !important;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s ease;
        padding: 6px 12px !important;
        border-radius: 8px;
    }

