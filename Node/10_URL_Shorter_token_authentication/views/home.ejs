<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 800px;
            margin: 30px auto;
            padding: 20px;
        }

        h1 {
            margin-bottom: 20px;
        }

        input {
            width: 70%;
            padding: 8px;
        }

        button {
            padding: 8px 15px;
        }

        .generated {
            margin: 15px 0;
            color: green;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th,
        td {
            border: 1px solid #ccc;
            padding: 10px;
            text-align: left;
        }

        th {
            background-color: #f2f2f2;
        }
    </style>
</head>

<body>

    <h1>URL Shortener</h1>

    <form method="POST" action="/ShortUrl">
        <input type="text" name="url" placeholder="Enter URL" required>
        <button type="submit">Generate</button>
    </form>

    <% if(typeof id !=="undefined" ){ %>
        <div class="generated">
            Short URL:
            <a href="/ShortUrl/<%= id %>" target="_blank">
                http://localhost:8001/ShortUrl/<%= id %>
            </a>
        </div>
        <% } %>

            <table>
                <thead>
                    <tr>
                        <th>Short URL</th>
                        <th>Original URL</th>
                        <th>Visits</th>
                    </tr>
                </thead>

                <tbody>

                    <% if(urls && urls.length> 0){ %>

                        <% urls.forEach((url)=>{ %>

                            <tr>
                                <td>
                                    <a href="/ShortUrl/<%= url.shortId %>" target="_blank">
                                        <%= url.shortId %>
                                    </a>
                                </td>

                                <td>
                                    <%= url.redirectURL %>
                                </td>

                                <td>
                                    <%= url.visitHistory.length %>
                                </td>
                            </tr>

                            <% }) %>

                                <% } else { %>

                                    <tr>
                                        <td colspan="3">No URLs Found</td>
                                    </tr>

                                    <% } %>

                </tbody>
            </table>

</body>

</html>